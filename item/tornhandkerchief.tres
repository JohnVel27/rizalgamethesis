[resource]
script = ExtResource("1_jk2ln")
name = "Torn Handkerchief"
description = "A handkerchief that was torn after Rizal’s first fight with a classmate in Biñan. Although he was smaller than his opponent, he showed the courage and determination to defend himself. From this, he learned that strength is not only measured by the body, but by the person's inner character."
metadata/_custom_type_script = "uid://c04jwa6ijx6sq"
