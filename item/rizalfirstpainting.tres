script = ExtResource("1_jp2x3")
name = "Rizal’s First Painting"
description = "One of Rizal’s first artworks, created under the guidance of Juancho Carrera. Through painting, he learned to express his observations of the world. Art became one of his ways to showcase the truth and beauty of life."
